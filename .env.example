# ╔══════════════════════════════════════════════════════════════════╗
# ║  All values below are development defaults.                     ║
# ║  Generate strong secrets before any non-local deployment:       ║
# ║    AUTH_PRIVATE_KEY:  openssl genrsa -out private.pem 2048      ║
# ║    SIGNING_KEY:       openssl genpkey -algorithm ed25519 ...    ║
# ║                                                                 ║
# ║  Set DEMO_MODE=false in production.                              ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_USER=governance
POSTGRES_PASSWORD=governance_secret
POSTGRES_DB=evidence_store
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Neo4j ────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=governance_secret

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Python Backend ───────────────────────────────────────────────
PYTHON_BACKEND_URL=http://python-backend:8000

# ─── Auth (OAuth 2.1 / RBAC / RS256 JWT) ─────────────────────────
# RS256 private key in PEM format (set path or inline)
# Generate with: openssl genrsa -out private.pem 2048
#                openssl rsa -in private.pem -pubout -out public.pem
AUTH_PRIVATE_KEY_PATH=
AUTH_PRIVATE_KEY=
AUTH_TOKEN_EXPIRE_MINUTES=60
AUTH_REFRESH_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:3001,http://localhost:5173
TRUSTED_HOSTS=localhost,python-backend,mcp-server,127.0.0.1

# Development mode: set to "true" to bypass authentication for local dev
DEMO_MODE=true

# Pre-configured service account token for MCP <-> backend communication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_TOKEN=

# ─── Crypto (W3C VC Signing) ─────────────────────────────────────
# Ed25519 private key in PEM format (base64-encoded for env var)
# Generate with: openssl genpkey -algorithm ed25519 -out private.pem
SIGNING_KEY_PRIVATE=
SIGNING_KEY_PUBLIC=

# ─── MCP Server ──────────────────────────────────────────────────
# Transport mode: stdio (default), sse, or streamable-http
#   stdio:           For Claude Desktop and CLI integration
#   sse:             For web-based MCP clients via GET /sse + POST /messages
#   streamable-http: For modern MCP clients via POST/GET/DELETE /mcp
MCP_TRANSPORT=stdio
MCP_PORT=3000

# ─── Adversarial Testing (Phase 6) ────────────────────────────────
# Real LLM endpoint for adversarial robustness evaluation.
# Supports any OpenAI-compatible API (OpenAI, vLLM, Ollama, etc.)
ADV_ENDPOINT_URL=
ADV_API_KEY=
ADV_TARGET_MODEL=gpt-4o-mini
ADV_JUDGE_MODEL=gpt-4o-mini
ADV_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Rate Limiting ───────────────────────────────────────────────
# Per-route rate tiers (requests per 60s window)
RATE_LIMIT_AUTH=20    # /api/auth/* endpoints
RATE_LIMIT_WRITE=60   # POST/PUT/DELETE /api/* endpoints
RATE_LIMIT_READ=120   # GET/HEAD /api/* endpoints

# ─── Input Size Limits ──────────────────────────────────────────
# Maximum request body size in bytes (default: 10 MB)
MAX_BODY_SIZE=10485760

# ─── Production Mode ─────────────────────────────────────────────
# When true, ephemeral keys are refused at startup.
# Requires AUTH_PRIVATE_KEY and SIGNING_KEY_PRIVATE to be set.
PRODUCTION_MODE=false

# ─── Trusted Timestamping ────────────────────────────────────────
# Number of evidence records to batch before Merkle anchoring
TIMESTAMP_BATCH_SIZE=100
# Optional: RFC 3161 TSA URL for external timestamp anchoring
RFC3161_TSA_URL=

# ─── Model / Data Discovery ──────────────────────────────────────
MODEL_DIR=./models
DATA_DIR=./data
