    "directory": "mcp-server"
  },
  "homepage": "https://github.com/nyayoshbharuchanb15-max/ComplianceStack#readme",
  "bugs": {
    "url": "https://github.com/nyayoshbharuchanb15-max/ComplianceStack/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-governance",
    "enterprise-compliance",
    "ai-compliance",
    "eu-ai-act",
    "gdpr",
    "iso-42001",
    "nist-ai-rmf",
    "dpdp",
    "audit",
    "data-privacy",
    "regulatory-compliance",
    "zero-data-egress",
    "w3c-verifiable-credentials",
    "bias-detection",
    "dpia",
    "ropa",
    "dsar",
    "adversarial-testing",
    "drift-detection"
